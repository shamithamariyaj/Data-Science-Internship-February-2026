#Problem 2: Online Food Delivery Time Estimator

def delivery_time_estimator(distance, traffic, weather):
    base_time = distance * 5   # 5 minutes per km

    # Traffic conditions
    if traffic == "High":
        base_time += 15
    elif traffic == "Medium":
        base_time += 8

    # Weather conditions
    if weather == "Rainy":
        base_time += 10
    elif weather == "Storm":
        base_time += 20

    print("Estimated Delivery Time:", int(base_time), "minutes")


# Sample Input
delivery_time_estimator(8, "High", "Rainy")

