#Premium Crop Price Filter
def premium_crops():
    price_list = list(map(int, input("Enter crop prices: ").split()))
    premium = []

    for price in price_list:
        if price > 2000:
            premium.append(price)

    print("Premium Crops:", premium)

premium_crops()

