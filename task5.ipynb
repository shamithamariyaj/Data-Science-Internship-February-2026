#Medicine Stock Alert
def medicine_stock():
    stock = int(input("Enter medicine stock: "))

    if stock < 10:
        status = "Low Stock Alert"
    else:
        status = "Stock Sufficient"

    print("Medicine Stock:", stock)
    print("Status:", status)

medicine_stock()


# %%
#Rainfall Adequacy Checker
def rainfall_checker():
    rainfall_list = list(map(int, input("Enter rainfall values: ").split()))
    required = int(input("Enter required rainfall level: "))

    total = 0
    for rain in rainfall_list:
        total += rain

    average = total / len(rainfall_list)

    if average >= required:
        status = "Adequate Rainfall"
    else:
        status = "Inadequate Rainfall"

    print("Average Rainfall:", average)
    print("Rainfall Status:", status)

rainfall_checker()

# %%
#Duplicate Account Detection
def check_duplicates():
    usernames = input("Enter usernames separated by space: ").split()

    if len(usernames) != len(set(usernames)):
        result = "Yes"
    else:
        result = "No"

    print("Duplicate Accounts Found:", result)

check_duplicates()

