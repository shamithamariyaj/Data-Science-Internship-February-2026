#Post Engagement Analyzer (with input)
def post_engagement():
    likes_list = list(map(int, input("Enter likes separated by space: ").split()))
    
    total_likes = 0
    for like in likes_list:
        total_likes += like

    if total_likes >= 1000:
        status = "Viral Post"
    else:
        status = "Normal Engagement"

    print("Total Likes:", total_likes)
    print("Post Status:", status)

post_engagement()

